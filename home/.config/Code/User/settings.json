{
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.confirmPasteNative": false,
    "security.workspace.trust.untrustedFiles": "open",
    "chat.disableAIFeatures": true,
    "editor.minimap.enabled": false,
    "editor.inlayHints.enabled": "off",
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.autoIndent": "full",
    "editor.semanticHighlighting.enabled": true,
    "editor.bracketPairColorization.enabled": false,
    "editor.guides.bracketPairs": false,
    "editor.guides.indentation": true,
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "editor.renderLineHighlight": "none",
    "editor.stickyScroll.enabled": false,
    "editor.codeLens": false,
    "editor.wordBasedSuggestions": "off",
    "editor.parameterHints.enabled": false,
    "editor.hover.delay": 250,
    "editor.hover.hidingDelay": 100,
    "editor.quickSuggestionsDelay": 300,
    "editor.fontFamily": "CommitMono Nerd Font Mono",
    "editor.fontSize": 14,
    "workbench.editorAssociations": {
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.ui": "default",
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "workbench.iconTheme": "chalice-icon-theme",
    "workbench.list.smoothScrolling": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "window.zoomLevel": 0.9,
    "terminal.integrated.fontFamily": "CommitMono Nerd Font Mono",
    "terminal.integrated.shellIntegration.enabled": false,
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.jj": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.classpath": true,
        "**/.settings": true,
        "**/Library/**": true,
        "**/Temp/**": true,
        "**/obj/**": true,
        "**/Build/**": true,
        "**/Builds/**": true,
        "**/Logs/**": true,
        "**/MemoryCaptures/**": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/Build/**": true,
        "**/Builds/**": true,
        "**/obj/**": true,
        "**/vcpkg_installed/**": true,
        "**/buildtrees/**": true,
        "**/downloads/**": true,
        "**/Logs/**": true,
        "**/MemoryCaptures/**": true
    },
    "search.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.jj": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.classpath": true,
        "**/.settings": true,
        "**/Library/**": true,
        "**/Temp/**": true,
        "**/obj/**": true,
        "**/Build/**": true,
        "**/Builds/**": true,
        "**/Logs/**": true,
        "**/MemoryCaptures/**": true
    },
    "search.followSymlinks": false,
    "git.decorations.enabled": false,
    "git.autorefresh": false,
    "qt-core.additionalQtPaths": [
        {
            "name": "Qt-5.15.18-linux-g++_from_PATH",
            "path": "/usr/bin/qtpaths"
        }
    ],
    "qt-qml.qmlls.customExePath": "/usr/lib/qt6/bin/qmlls",
    "qt-qml.qmlls.additionalImportPaths": [ "/usr/lib/qt6/qml" ],
    "cmake.additionalKits": [ "/home/rel/.local/share/qt-support/qt-kits.json" ],
    "cmake.enableAutomaticKitScan": false,
    "cmake.configureOnOpen": false,
    "cmake.automaticReconfigure": false,
    "cmake.configureOnEdit": false,
    "cmake.showConfigureWithDebuggerNotification": false,
    "cmake.autoSelectActiveFolder": false,
    "cmake.ignoreCMakeListsMissing": false,
    "cmake.debugConfig": { "console": "internalConsole" },
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.configurationWarnings": "disabled",
    "telemetry.telemetryLevel": "off",
    "extensions.autoUpdate": "off",
    "python.analysis.typeCheckingMode": "standard",
    "update.mode": "none",
    "[c]": { "editor.formatOnSave": false },
    "[cpp]": { "editor.formatOnSave": false },
    "[typescript]": { "editor.formatOnSave": false },
    "[typescriptreact]": { "editor.formatOnSave": false },
    "[javascript]": { "editor.formatOnSave": false },
    "[go]": { "editor.formatOnSave": false },
    "[python]": { "editor.formatOnSave": false },
    "workbench.colorTheme": "Dark Modern",
    "workbench.startupEditor": "none"
}
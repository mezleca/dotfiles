{
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.confirmPasteNative": false,
    "security.workspace.trust.untrustedFiles": "open",
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "editor.minimap.enabled": false,
    "editor.inlayHints.enabled": "off",
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.autoIndent": "none",
    "editor.semanticHighlighting.enabled": false,
    "editor.bracketPairColorization.enabled": false,
    "editor.guides.bracketPairs": false,
    "editor.guides.indentation": false,
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "editor.renderLineHighlight": "none",
    "editor.stickyScroll.enabled": false,
    "editor.codeLens": false,
    "editor.smoothScrolling": false,
    "editor.wordBasedSuggestions": "off",
    "editor.parameterHints.enabled": false,
    "editor.hover.delay": 1000,
    "editor.quickSuggestionsDelay": 300,
    "editor.fontFamily": "CommitMono Nerd Font Mono",
    "editor.fontSize": 16,
    "workbench.editorAssociations": {
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.ui": "default",
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.list.smoothScrolling": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.experimental.fontFamily": "Adwaita Sans",
    "workbench.experimental.fontSize": 16,
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "window.zoomLevel": 0.3,
    "terminal.integrated.fontFamily": "CommitMono Nerd Font Mono",
    "terminal.integrated.shellIntegration.enabled": false,
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.jj": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.classpath": true,
        "**/.settings": true,
        "**/Library/**": true,
        "**/Temp/**": true,
        "**/obj/**": true,
        "**/Build/**": true,
        "**/Builds/**": true,
        "**/Logs/**": true,
        "**/MemoryCaptures/**": true
    },
    "search.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.jj": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.classpath": true,
        "**/.settings": true,
        "**/Library/**": true,
        "**/Temp/**": true,
        "**/obj/**": true,
        "**/Build/**": true,
        "**/Builds/**": true,
        "**/Logs/**": true,
        "**/MemoryCaptures/**": true
    },
    "search.followSymlinks": false,
    "git.decorations.enabled": false,
    "clangd.path": "/usr/bin/clangd",
    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--function-arg-placeholders=0",
        "-j=2",
        "--background-index-priority=background"
    ],
    "qt-core.additionalQtPaths": [
        {
            "name": "Qt-5.15.18-linux-g++_from_PATH",
            "path": "/usr/bin/qtpaths"
        }
    ],
    "qt-qml.qmlls.customExePath": "/usr/lib/qt6/bin/qmlls",
    "qt-qml.qmlls.additionalImportPaths": [ "/usr/lib/qt6/qml" ],
    "qt-support.qtInstallDirectories": [],
    "cmake.additionalKits": [
        "/home/rel/.local/share/qt-support/qt-kits.json"
    ],
    "cmake.configureOnEdit": false,
    "cmake.showConfigureWithDebuggerNotification": false,
    "cmake.debugConfig": { "console": "internalConsole" },
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "telemetry.telemetryLevel": "off",
    "extensions.autoUpdate": false,
    "update.mode": "none",
    "[c]": { "editor.formatOnSave": false },
    "[cpp]": { "editor.formatOnSave": false },
    "[typescript]": { "editor.formatOnSave": false },
    "[typescriptreact]": { "editor.formatOnSave": false },
    "[javascript]": { "editor.formatOnSave": false },
    "[go]": { "editor.formatOnSave": false },
    "[python]": { "editor.formatOnSave": false }
}